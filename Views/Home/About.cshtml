@{
    ViewData["Title"] = "About";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h1 class="h3 mb-3">About Sports Store</h1>
        <p>
            Sports Store is a student-friendly sports e-commerce project inspired by modern retail websites.
            The goal is to provide a clean and high-energy shopping experience where users can discover products by category,
            compare options quickly, and check out with confidence.
        </p>
        <p>
            This project demonstrates the complete MVC workflow using ASP.NET Core, Bootstrap 5,
            Entity Framework Core, and session-based cart management.
        </p>
        <hr />
        <h2 class="h5 mb-3">Quick Random Facts</h2>
        <ul class="mb-3">
            <li>Average athlete replaces running shoes every 500–800 km.</li>
            <li>Hydration can impact endurance performance by up to 20%.</li>
            <li>Compression-ready gear can help reduce post-training soreness.</li>
            <li>Most team players keep at least two jersey sets per season.</li>
        </ul>
        <hr />
        <p class="mb-1"><strong>Created By:</strong> Aaron Vallega</p>
        <p class="mb-1"><strong>Email:</strong> vallegaaron13@gmail.com</p>
        <p class="mb-0"><strong>Mission:</strong> Build an easy-to-use sports shopping app that feels fast, modern, and practical for real users.</p>
    </div>
</div>

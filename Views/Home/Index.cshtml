@{
    ViewData["Title"] = "Home";
}

<section class="hero-banner rounded-4 p-5 mb-4 text-white">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <p class="text-uppercase small fw-semibold mb-2 text-warning">Performance Collection 2026</p>
            <h1 class="display-5 fw-bold">Move Faster. Train Smarter. Win More.</h1>
            <p class="lead mb-4">Explore elite footwear, team-ready jerseys, and match-day essentials in a bold modern store inspired by top global sports retailers.</p>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Product" asp-action="Products" class="btn btn-accent btn-lg">Shop Products</a>
                <a asp-controller="Product" asp-action="Products" asp-route-category="Shoes" class="btn btn-outline-light btn-lg">Shop Shoes</a>
            </div>
        </div>
        <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
            <img src="https://images.unsplash.com/photo-1461896836934-ffe607ba8211?auto=format&fit=crop&w=900&q=80" class="img-fluid rounded-4 shadow" alt="Sports banner" />
        </div>
    </div>
</section>

<section class="row g-4">
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <h3>Pro-Level Selection</h3>
            <p class="mb-0">Curated sports gear built for comfort, performance, and everyday training.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <h3>Style + Performance</h3>
            <p class="mb-0">Clean product presentation inspired by the latest digital sports storefronts.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card p-4 h-100">
            <h3>Fast Cart Experience</h3>
            <p class="mb-0">Add to cart in one click and finish checkout with a straightforward flow.</p>
        </div>
    </div>
</section>

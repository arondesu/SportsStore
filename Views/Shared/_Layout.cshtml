<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportsStore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SportsStore.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var cartItems = Context.Session.GetObject<List<CartItem>>("Cart") ?? new List<CartItem>();
        var cartCount = cartItems.Sum(c => c.Quantity);
        var cartTotal = cartItems.Sum(c => c.LineTotal);
    }

    <header>
        <div class="top-strip py-2">
            <div class="container d-flex flex-wrap justify-content-between gap-2 small">
                <span>Free shipping on orders above ₱3,000</span>
                <span>Need help? Visit Contact page for support</span>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg navbar-dark sports-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">S</span>
                    <span>Sports Store</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Products">Products</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Categories</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Products" asp-route-category="Shoes">Shoes</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Products" asp-route-category="Jerseys">Jerseys</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Products" asp-route-category="Equipment">Equipment</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Products" asp-route-category="Accessories">Accessories</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>

                    <a asp-controller="Cart" asp-action="Cart" class="btn btn-accent btn-sm mt-2 mt-lg-0">
                        Cart (@cartCount items) - ₱@cartTotal.ToString("N0")
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container py-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer sports-footer text-light py-3 mt-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <span>&copy; 2026 Sports Store Application</span>
                <span>Built with ASP.NET Core MVC, Bootstrap 5, and EF Core</span>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

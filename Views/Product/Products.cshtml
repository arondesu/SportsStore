@model List<Product>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var currentCategory = ViewBag.CurrentCategory as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-2 mb-md-0">Products Catalog</h1>
    <div class="category-nav d-flex flex-wrap gap-2">
        <a asp-controller="Product" asp-action="Products" class="btn btn-sm @(string.IsNullOrWhiteSpace(currentCategory) ? "btn-accent" : "btn-outline-dark")">All</a>
        @foreach (var category in categories)
        {
            <a asp-controller="Product" asp-action="Products" asp-route-category="@category" class="btn btn-sm @(currentCategory == category ? "btn-accent" : "btn-outline-dark")">@category</a>
        }
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 product-card border-0 shadow-sm">
                <img src="@product.ImageUrl" class="card-img-top product-image" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <span class="badge bg-dark mb-2 align-self-start">@product.Category</span>
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                    <p class="h5 text-accent mb-3">₱@product.Price.ToString("N0")</p>
                    <div class="d-flex gap-2 mt-auto">
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-100">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="btn btn-accent w-100">Add to Cart</button>
                        </form>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-dark w-100">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (totalPages > 1)
{
    <nav class="mt-4" aria-label="Products pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Products" asp-route-category="@currentCategory" asp-route-page="@(currentPage - 1)">Previous</a>
            </li>

            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Products" asp-route-category="@currentCategory" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Products" asp-route-category="@currentCategory" asp-route-page="@(currentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
